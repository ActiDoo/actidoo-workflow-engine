<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_off" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_off">
    <bpmn:participant id="Participant_off" name="Vorlagen – Off" processRef="TestFlowTplOff" />
  </bpmn:collaboration>
  <bpmn:process id="TestFlowTplOff" name="Vorlagen – Off" isExecutable="true">
    <bpmn:laneSet id="LaneSet_off">
      <bpmn:lane id="InitLane" name="Init Lane">
        <bpmn:extensionElements>
          <zeebe:properties>
            <zeebe:property name="initiator" value="true" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:flowNodeRef>StartEvent_off</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OffForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_off</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_off">
      <bpmn:outgoing>Flow_start_task</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="OffForm" name="Off-Formular">
      <bpmn:incoming>Flow_start_task</bpmn:incoming>
      <bpmn:outgoing>Flow_task_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_off">
      <bpmn:incoming>Flow_task_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_task" sourceRef="StartEvent_off" targetRef="OffForm" />
    <bpmn:sequenceFlow id="Flow_task_end" sourceRef="OffForm" targetRef="EndEvent_off" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_off">
      <bpmndi:BPMNShape id="Participant_off_di" bpmnElement="Participant_off" isHorizontal="true">
        <dc:Bounds x="100" y="60" width="600" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="InitLane_di" bpmnElement="InitLane" isHorizontal="true">
        <dc:Bounds x="130" y="60" width="570" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_off_di" bpmnElement="StartEvent_off">
        <dc:Bounds x="180" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="OffForm_di" bpmnElement="OffForm">
        <dc:Bounds x="280" y="118" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_off_di" bpmnElement="EndEvent_off">
        <dc:Bounds x="440" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_task_di" bpmnElement="Flow_start_task">
        <di:waypoint x="216" y="158" />
        <di:waypoint x="280" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_task_end_di" bpmnElement="Flow_task_end">
        <di:waypoint x="380" y="158" />
        <di:waypoint x="440" y="158" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
